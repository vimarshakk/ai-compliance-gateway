{
  "name": "@acg/cli",
  "version": "0.1.0",
  "description": "AI Compliance Gateway CLI — scan, score, simulate, and manage AI compliance locally",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "acg": "./bin/acg.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsc --watch",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@acg/kernel": "workspace:*",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "glob": "^10.3.0",
    "ora": "^8.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
