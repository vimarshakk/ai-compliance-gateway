# AI Compliance Gateway - Environment Variables

# Gateway
GATEWAY_PORT=3000
GATEWAY_HOST=0.0.0.0
LOG_LEVEL=info
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
BODY_LIMIT=10485760

# Service URLs
LITELLM_URL=http://litellm:4000
PRESIDIO_ANALYZER_URL=http://presidio-analyzer:3000
PRESIDIO_ANONYMIZER_URL=http://presidio-anonymizer:3000
OPA_URL=http://opa:8181
GUARDRAILS_URL=http://nemo-guardrails:8000
OTEL_COLLECTOR_URL=http://otel-collector:4318

# Admin
ADMIN_PORT=3002
ADMIN_HOST=0.0.0.0

# Evaluator
EVALUATOR_PORT=3003
EVALUATOR_HOST=0.0.0.0

# LLM Providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
LITELLM_MASTER_KEY=sk-acg-master-key-change-in-production

# Database
POSTGRES_PASSWORD=acg_dev_password
POSTGRES_URL=postgresql://acg:acg_dev_password@postgres:5432/acg

# Redis
REDIS_URL=redis://redis:6379

# NATS
NATS_URL=nats://nats:4222

# Keycloak
KEYCLOAK_ADMIN_PASSWORD=admin

# Vault
VAULT_ROOT_TOKEN=dev-only-token

# MinIO
MINIO_PASSWORD=minio_dev_password

# Grafana
GRAFANA_PASSWORD=admin

# NextAuth (for Langfuse)
NEXTAUTH_SECRET=dev-secret-change-in-production

# CORS
CORS_ORIGIN=http://localhost:3004,http://localhost:3000
